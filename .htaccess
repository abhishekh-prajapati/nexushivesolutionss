Options -Indexes
RewriteEngine On

# -------------------------------------------------------
# NexusHive CMS API Routes (MilesWeb / Apache shared hosting)
# Routes clean API URLs to their PHP handler files
# -------------------------------------------------------

# GET /api/data/:filename  →  php/data.php?file=:filename
RewriteRule ^api/data/([a-zA-Z0-9_\-]+\.json)$ php/data.php?file=$1 [QSA,L]

# POST /api/save  →  php/save.php
RewriteRule ^api/save$ php/save.php [QSA,L]

# POST /api/upload-image  →  php/upload-image.php
RewriteRule ^api/upload-image$ php/upload-image.php [QSA,L]

# -------------------------------------------------------
# Security: block direct access to raw data files
# -------------------------------------------------------
<FilesMatch "\.(json)$">
    <IfModule mod_rewrite.c>
        RewriteCond %{REQUEST_URI} ^/data/
        RewriteRule .* - [F,L]
    </IfModule>
</FilesMatch>

# Block access to server config files
<FilesMatch "(^\.htaccess|server\.js|package\.json|vercel\.json)$">
    Order allow,deny
    Deny from all
</FilesMatch>
