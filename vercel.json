{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/data/:filename", "destination": "/api/data.js?file=:filename" },
    { "source": "/api/save", "destination": "/api/save.js" },
    { "source": "/api/upload-image", "destination": "/api/upload-image.js" }
  ]
}
